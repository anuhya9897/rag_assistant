# Copy to .env and fill in values. Never commit .env.

# Ollama (local chat / embeddings)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Azure OpenAI (GPT models in UI under "OpenAI / GPT")
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-key-here
AZURE_OPENAI_API_VERSION=2024-08-01-preview
# Deployment name(s) from Azure OpenAI Studio (comma-separated)
RAG_OPENAI_MODELS=gpt-5.4

# Optional: direct OpenAI instead of Azure (do not set both unless you intend Azure to win)
# OPENAI_API_KEY=sk-...

# Optional Ollama tags in dropdown before install (comma-separated); Refresh pulls selected tag
# RAG_OLLAMA_EXTRA_MODELS=gemma3:8b,llama3.1:16b

# Embeddings / index (default)
# RAG_EMBED_PROVIDER=ollama
